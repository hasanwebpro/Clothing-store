# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=clothing_store
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (Gmail SMTP for dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@clothingstore.com

# JazzCash
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_password
JAZZCASH_INTEGRITY_SALT=your_salt
JAZZCASH_RETURN_URL=http://localhost:3000/checkout/jazzcash-return

# Easypaisa
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/
